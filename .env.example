JWT_SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-long-admin-password
APP_BASE_URL=http://localhost:3000
# Use an Atlas cluster or a MongoDB replica set. Entity writes use transactions to
# atomically advance users.syncVersion and stamp the changed document.
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGODB_DB_NAME=messenger
# Used by the private Vercel Blob-compatible store for user and agent avatar files only.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_local_emulator_secret
BLOB_STORE_ID=local
# The local emulator exposes both the control API and blob storage on port 3100.
VERCEL_BLOB_API_URL=http://localhost:3100/api/blob
VERCEL_BLOB_STORAGE_URL=http://localhost:3100/blob
VERCEL_BLOB_RETRIES=0
