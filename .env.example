JWT_SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-long-admin-password
APP_BASE_URL=http://localhost:3000
# Use an Atlas cluster or a MongoDB replica set. Entity writes use transactions to
# atomically advance users.syncVersion and stamp the changed document.
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGODB_DB_NAME=messenger
# Used by the private Vercel Blob store for user and agent avatar files only.
BLOB_READ_WRITE_TOKEN=
